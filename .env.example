# === APP ===
APP_NAME=clothes-api
SPRING_PROFILES_ACTIVE=docker

# === PORT ===
HOST_PORT=8080
SERVER_PORT=8080

# === DATABASE ===
DB_HOST=mysql
DB_PORT=3306
DB_NAME=clothes_db
DB_USERNAME=clothes_user
DB_PASSWORD=password
DB_ROOT_PASSWORD=root

DB_EXTERNAL_PORT=3306

DB_CREATE_IF_NOT_EXIST=true
DB_USE_SSL=false
DB_TIMEZONE=Asia/Ho_Chi_Minh

DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_TEST_QUERY=SELECT 1

# === JPA ===
JPA_SHOW_SQL=false
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
HIBERNATE_SQL_COMMENTS=true
HIBERNATE_BATCH_SIZE=20
HIBERNATE_ORDER_INSERTS=true
HIBERNATE_ORDER_UPDATES=true

# === FLYWAY ===
FLYWAY_LOCATIONS=classpath:db/migration

# === MAIL ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_CONNECTION_TIMEOUT=5000
MAIL_TIMEOUT=5000
MAIL_WRITE_TIMEOUT=5000

# === OAUTH2 ===
GOOGLE_CLIENT_ID=changeme-google-client-id
GOOGLE_CLIENT_SECRET=changeme-google-client-secret
GOOGLE_SCOPES=email,profile

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === SERVER ===
SERVER_MAX_THREADS=200
SERVER_MIN_THREADS=20
SERVER_MAX_CONNECTIONS=1000
SERVER_ACCEPT_COUNT=100
SERVER_CONNECTION_TIMEOUT=5000
SERVER_CONTEXT_PATH=/api/clothes

# === JWT ===
JWT_SECRET=MySuperSecretKeyForJwtThatIsAtLeast32CharsLong
JWT_ACCESS_EXPIRATION=PT10M
JWT_REFRESH_EXPIRATION=P7D
JWT_RESET_PASSWORD_EXPIRATION=PT15M
JWT_ISSUER=Clothes-API
TOKEN_BLACKLIST_CLEANUP_CRON=0 0 3 * * *

# === CORS ===
CORS_ALLOWED_ORIGINS=https://yourdomain
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=PT1H

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret